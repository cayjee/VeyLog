# ==============================================================
# Veylog — Configuration de l'environnement
# Copier ce fichier en .env et adapter les valeurs
# ==============================================================

# Port d'écoute du serveur web Veylog
PORT=3000

# URL de l'API Ollama
# En Docker Compose : http://ollama:11434
# En local (hors Docker) : http://localhost:11434
OLLAMA_URL=http://ollama:11434

# Modèle Ollama à utiliser par défaut
# Exemples : llama3.3:70b, qwen2.5:32b, mistral:7b, llama3.1:8b
DEFAULT_MODEL=llama3.3:70b

# Chemin du volume contenant les logs (monté en :ro dans docker-compose)
LOGS_PATH=/var/log

# Nombre maximum de lignes à analyser par fichier
MAX_LINES=300
